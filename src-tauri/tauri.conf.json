{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Scrivus",
  "version": "0.2.7",
  "identifier": "com.obsydianx.scrivus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Scrivus",
        "width": 1280,
        "height": 720,
        "minWidth": 600,
        "minHeight": 400,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "ObsydianX",
    "homepage": "https://github.com/ObsydianX/Scrivus",
    "copyright": "Copyright (c) 2026 ObsydianX",
    "license": "MIT",
    "licenseFile": "../LICENSE.txt",
    "category": "Productivity",
    "shortDescription": "A local-first novel writing app.",
    "longDescription": "Scrivus is a local-first writing app for drafting, organizing, planning, and compiling long-form fiction projects.",
    "resources": {
      "../dist/THIRD_PARTY_LICENSES.txt": "."
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "both",
        "headerImage": "icons/installer-header.bmp",
        "sidebarImage": "icons/installer-sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "uninstallerHeaderImage": "icons/installer-header.bmp",
        "startMenuFolder": "Scrivus"
      }
    }
  }
}
